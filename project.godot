; Engine configuration file.
; It's best edited using the editor UI and not directly,
; but the project may still be edited manually.

config_version=5

[application]

config/name="The Blood Bloom"
config/name_localized={
"zh": "鮮血花期"
}
config/run/main_scene="res://scenes/ui/MainMenu.tscn"
config/features=PackedStringArray("4.4", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

GameManager="*res://scripts/autoload/GameManager.gd"
AudioManager="*res://scripts/autoload/AudioManager.gd"
LocalizationManager="*res://scripts/autoload/LocalizationManager.gd"
InputController="*res://scripts/autoload/InputController.gd"

[display]

window/size/viewport_width=320
window/size/viewport_height=180
window/size/window_width_override=1280
window/size/window_height_override=720
window/stretch/mode="canvas_items"
window/stretch/aspect="keep"
window/stretch/scale_mode="integer"

