[gd_scene load_steps=2 format=3 uid="uid://pause001"]

[ext_resource type="Script" path="res://scenes/ui/PauseMenu.gd" id="1_pause"]

[node name="PauseMenu" type="CanvasLayer"]
layer = 20
script = ExtResource("1_pause")

[node name="RootPanel" type="ColorRect" parent="."]
offset_left = 0.0
offset_top = 0.0
offset_right = 320.0
offset_bottom = 180.0
color = Color(0.0, 0.0, 0.0, 0.7)

[node name="MainButtons" type="VBoxContainer" parent="RootPanel"]
offset_left = 100.0
offset_top = 50.0
offset_right = 220.0
offset_bottom = 140.0
theme_override_constants/separation = 6

[node name="TitleLabel" type="Label" parent="RootPanel/MainButtons"]
layout_mode = 2
theme_override_font_sizes/font_size = 8
horizontal_alignment = 1
text = "— PAUSED —"

[node name="ResumeButton" type="Button" parent="RootPanel/MainButtons"]
layout_mode = 2
text = &"PAUSE_RESUME"

[node name="LoreArchiveButton" type="Button" parent="RootPanel/MainButtons"]
layout_mode = 2
text = &"PAUSE_LORE_ARCHIVE"

[node name="OptionsButton" type="Button" parent="RootPanel/MainButtons"]
layout_mode = 2
text = &"PAUSE_OPTIONS"

[node name="QuitButton" type="Button" parent="RootPanel/MainButtons"]
layout_mode = 2
text = &"PAUSE_QUIT"

[node name="LorePanel" type="VBoxContainer" parent="RootPanel"]
offset_left = 20.0
offset_top = 20.0
offset_right = 300.0
offset_bottom = 165.0
visible = false

[node name="LoreTitleLabel" type="Label" parent="RootPanel/LorePanel"]
layout_mode = 2
theme_override_font_sizes/font_size = 8
text = &"LORE_ARCHIVE_TITLE"

[node name="ScrollContainer" type="ScrollContainer" parent="RootPanel/LorePanel"]
layout_mode = 2
size_flags_vertical = 3

[node name="LoreText" type="RichTextLabel" parent="RootPanel/LorePanel/ScrollContainer"]
layout_mode = 2
theme_override_font_sizes/font_size = 6
bbcode_enabled = true
fit_content = true

[node name="BackButton" type="Button" parent="RootPanel/LorePanel"]
layout_mode = 2
text = &"BTN_BACK"

[connection signal="pressed" from="RootPanel/MainButtons/ResumeButton" to="." method="_on_resume_pressed"]
[connection signal="pressed" from="RootPanel/MainButtons/LoreArchiveButton" to="." method="_on_lore_archive_pressed"]
[connection signal="pressed" from="RootPanel/MainButtons/OptionsButton" to="." method="_on_options_pressed"]
[connection signal="pressed" from="RootPanel/MainButtons/QuitButton" to="." method="_on_quit_pressed"]
[connection signal="pressed" from="RootPanel/LorePanel/BackButton" to="." method="_on_lore_back_pressed"]
